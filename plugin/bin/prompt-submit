#!/usr/bin/env bash
# bin/prompt-submit — UserPromptSubmit hook.
#
# Pipes the hook's stdin JSON straight into `collab-claw post-prompt
# --from-hook`, which uses JSON.parse to extract `.prompt`. No jq, no
# sed-regex hacks — those broke on escaped quotes and multiline prompts.
#
# Fail-open: we never block the host's input. exit 0 always.

set -uo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_resolve.sh"

if [[ -z "$COLLAB_CLAW" ]]; then
  exit 0
fi

$COLLAB_CLAW post-prompt --from-hook 2>/dev/null || true
exit 0
